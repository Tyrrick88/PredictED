# Railway backend variables for the PredictED Spring Boot service.
# Paste these into the Railway backend service Variables tab.

SPRING_PROFILES_ACTIVE=postgres
NIXPACKS_JDK_VERSION=21
PORT=8080
JWT_SECRET=replace-with-a-random-production-secret-at-least-64-characters
CORS_ALLOWED_ORIGIN_PATTERNS=https://predict-ed.vercel.app

AI_PROVIDER=fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

UPLOAD_ROOT=/data/uploads
UPLOAD_MAX_FILE_SIZE=20MB
UPLOAD_MAX_REQUEST_SIZE=25MB
UPLOAD_MAX_FILE_BYTES=20971520

# These references assume your Railway database service is named "Postgres".
# If Railway named it differently, change "Postgres" to that service name.
PGHOST=${{Postgres.PGHOST}}
PGPORT=${{Postgres.PGPORT}}
PGDATABASE=${{Postgres.PGDATABASE}}
PGUSER=${{Postgres.PGUSER}}
PGPASSWORD=${{Postgres.PGPASSWORD}}
